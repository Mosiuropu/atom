'scopeName': 'source.fasta.nucleotide'
'name': 'FASTA Nucleotide'
'fileTypes': ['fasta', 'fa', 'fna', 'ffn', 'frn', 'fas']
'patterns': [
  {
    'match': '^>(.*)$'
    'name': 'entity.name.function.fasta'
    'captures':
      '1':
        'name': 'string.unquoted.fasta'
  }
  {
    'match': '^([ACGTURYSWKMBDHVNacgturyswkmbdhvn]+)$'
    'name': 'constant.character.nucleotide.fasta'
  }
  {
    'match': '^;.*$'
    'name': 'comment.line.semicolon.fasta'
  }
]
